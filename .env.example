# Copy this file to .env and fill in your real values.

# Brand / contact details shown across the site
SITE_NAME=BestFixIt
SITE_DOMAIN=bestfixit.ae
CONTACT_PHONE=+971 50 000 0000
WHATSAPP_NUMBER=971500000000
CONTACT_EMAIL=hello@bestfixit.ae

# Flask
SECRET_KEY=please-change-this-to-a-long-random-string

# Where enquiries are stored (one JSON object per line)
LEADS_FILE=leads.jsonl

# Optional: email enquiries via SMTP. Leave blank to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_TO=hello@bestfixit.ae
